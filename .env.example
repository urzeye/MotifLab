# RenderInk system-level environment variables
# 复制此文件为 .env 后按需修改。模型 API Key 请在 YAML/设置页中配置，不放在 .env。

# ==================== 配置与存储模式 ====================

# 配置存储模式: yaml | supabase
CONFIG_STORAGE_MODE=yaml

# 配置存储表名（当 CONFIG_STORAGE_MODE=supabase 时生效）
CONFIG_SUPABASE_TABLE=app_configs

# 历史记录存储模式: local | supabase
HISTORY_STORAGE_MODE=local

# ==================== Supabase（可选） ====================

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-service-role-key

# ==================== 访问控制与限流（可选） ====================

# 设置后启用 API 访问令牌认证（前端需携带 Authorization: Bearer <token>）
REDINK_AUTH_TOKEN=

# 全局速率限制（flask-limiter 语法）
REDINK_RATE_LIMIT=60 per minute

# ==================== 图片生成稳定性（可选） ====================

# 图片生成请求超时（秒）
IMAGE_GEN_TIMEOUT=300
IMAGE_API_TIMEOUT=300

# 图片下载超时（秒）
IMAGE_DOWNLOAD_TIMEOUT=60

# 单图失败自动重试次数（0 表示不自动重试）
IMAGE_RETRY_COUNT=1
