# RenderInk 环境变量示例
# 复制此文件为 .env 后按需修改。
# 说明：
# 1) 大部分变量未设置时会使用代码默认值。
# 2) 模型 API Key 优先在设置页/YAML 配置；如需环境变量注入，可在 YAML 中使用 ${VAR_NAME}，
#    或使用本文件提供的 DASHSCOPE_API_KEY 兜底变量。

# ==================== 必填 ====================

# 配置存储模式: yaml | supabase
CONFIG_STORAGE_MODE=yaml

# 图文历史存储模式: local | supabase
HISTORY_STORAGE_MODE=local

# 概念历史存储模式: local | supabase
CONCEPT_HISTORY_STORAGE_MODE=local

# 当 CONFIG_STORAGE_MODE=supabase 或 HISTORY_STORAGE_MODE=supabase 或
# CONCEPT_HISTORY_STORAGE_MODE=supabase 时，以下 Supabase 凭据为必填。
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-service-role-key

# 配置存储表名（仅当 CONFIG_STORAGE_MODE=supabase 时生效）
CONFIG_SUPABASE_TABLE=app_configs

# ==================== 可选（未设置则使用默认值） ====================

# 项目根目录（通常无需设置）
RENDERINK_ROOT=

# 应用运行环境: development | production | test
APP_ENV=development

# 应用信息覆盖项（默认读取 pyproject.toml 的 [project].description / [project].version）
REDINK_APP_NAME=
REDINK_APP_VERSION=

# 服务启动配置
REDINK_DEBUG=true
REDINK_LOG_LEVEL=DEBUG
REDINK_HOST=0.0.0.0
REDINK_PORT=12398

# 结构化日志开关
REDINK_STRUCTURED_LOG=true

# CORS 允许来源，多个用英文逗号分隔
REDINK_CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# 设置后启用 API 访问令牌认证（前端需携带 Authorization: Bearer <token>）
REDINK_AUTH_TOKEN=

# 全局速率限制（flask-limiter 语法）
REDINK_RATE_LIMIT=60 per minute

# 速率限制存储后端（默认内存）。生产建议使用 redis://...
REDINK_RATE_LIMIT_STORAGE_URI=memory://

# 数据库连接串（优先 REDINK_DATABASE_URL，其次 DATABASE_URL）
# 留空则默认使用本地 SQLite: data/redink.db
REDINK_DATABASE_URL=
DATABASE_URL=

# 图片生成稳定性参数（秒）
IMAGE_GEN_TIMEOUT=300
IMAGE_API_TIMEOUT=300
IMAGE_DOWNLOAD_TIMEOUT=60

# 单图失败自动重试次数（0 表示不自动重试）
IMAGE_RETRY_COUNT=1

# 异步图片任务线程池 worker 数
IMAGE_JOB_MAX_WORKERS=2

# 图片生成并发控制
GEMINI_MAX_CONCURRENT=1
GEMINI_HIGH_CONCURRENCY=false

# DashScope API Key 兜底变量（设置页/YAML 未配置时才会使用）
DASHSCOPE_API_KEY=

# ==================== 仅脚本（平时无需设置） ====================

# 仅 backend/migrations/run_migration.py 使用，二选一：
# 1) 直接提供完整连接串
SUPABASE_DB_URL=

# 2) 仅提供数据库密码（脚本会按内置 project_ref 组装连接串）
SUPABASE_DB_PASSWORD=
