# RenderInk API Keys
# 复制此文件为 .env 并填写你的 API keys

# ==================== 文本生成 API ====================

# OpenAI API
OPENAI_API_KEY=sk-your-openai-api-key

# Google Gemini (文本生成)
GEMINI_TEXT_API_KEY=your-gemini-text-api-key

# OpenRouter API
OPENROUTER_API_KEY=sk-or-your-openrouter-api-key

# ==================== 图片生成 API ====================

# Google Gemini (图片生成)
GEMINI_IMAGE_API_KEY=your-gemini-image-api-key

# ==================== 数据库 ====================

# Supabase (可选，用于云端存储历史记录)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-service-role-key

# ==================== 访问控制（可选） ====================

# 设置后启用 API 访问令牌认证（前端需携带 Authorization: Bearer <token>）
REDINK_AUTH_TOKEN=

# 全局速率限制（flask-limiter 语法）
REDINK_RATE_LIMIT=60 per minute

# ==================== 图片生成稳定性（可选） ====================

# 图片生成请求超时（秒）
IMAGE_GEN_TIMEOUT=300
IMAGE_API_TIMEOUT=300

# 图片下载超时（秒）
IMAGE_DOWNLOAD_TIMEOUT=60

# 单图失败自动重试次数（0 表示不自动重试）
IMAGE_RETRY_COUNT=1
