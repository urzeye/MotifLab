# 搜索抓取配置（可选）
# 复制为 search_providers.yaml 后修改

# 当前激活的搜索服务商
active_provider: firecrawl

providers:
  firecrawl:
    type: firecrawl
    enabled: false
    # 云服务通常需要；本地部署可按实际情况留空
    api_key: ""
    # 留空默认使用 https://api.firecrawl.dev
    # 本地部署示例: http://localhost:3002
    base_url: ""

  exa:
    type: exa
    enabled: false
    api_key: ""
    # 留空默认使用 https://api.exa.ai
    base_url: ""
